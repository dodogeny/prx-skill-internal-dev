{
  "permissions": {
    "allow": [
      "Bash(python3 *)",
      "Bash(xargs cat *)",
      "Skill(update-config)",
      "Bash(grep -n * plugin/skills/dev/SKILL.md)",
      "Bash(grep -n * plugin/skills/dev/SKILL.md)",
      "WebFetch(domain:www.npmjs.com)",
      "WebFetch(domain:github.com)",
      "Bash(chmod +x *)",
      "Bash(npx --yes ccusage@latest *)",
      "WebFetch(domain:asana.com)",
      "mcp__plugin_claude-mem_mem-search__get_observation",
      "Bash(awk '/^### Step R9/,/^### Step R10/' plugin/skills/dev/SKILL.md)",
      "Bash(awk '/^### Step 13/,/^### Step 14/' plugin/skills/dev/SKILL.md)",
      "Bash(git add *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/load-env.sh",
            "statusMessage": "Loading .env..."
          },
          {
            "type": "command",
            "command": "bash scripts/check-budget.sh",
            "statusMessage": "Checking monthly Claude budget..."
          }
        ]
      }
    ]
  }
}
